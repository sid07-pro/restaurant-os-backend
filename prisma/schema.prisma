// prisma/schema.prisma

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
  WAITER
  KITCHEN_STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     // Hashed with bcrypt
  name         String
  role         Role       @default(WAITER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]

  @@index([email])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // e.g. "LOGIN", "FIRE_KOT", "SETTLE_BILL"
  details   String   // Text or serialized JSON
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
}
