// prisma/schema.prisma

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
  WAITER
  KITCHEN_STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     // Hashed with bcrypt
  name         String
  role         Role       @default(WAITER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]

  @@index([email])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // e.g. "LOGIN", "FIRE_KOT", "SETTLE_BILL"
  details   String   // Text or serialized JSON
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  OUT_OF_SERVICE
}

model Table {
  id          String      @id @default(uuid())
  tableNumber String      @unique
  name        String?
  capacity    Int
  status      TableStatus @default(AVAILABLE)
  notes       String?
  orders      Order[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  menuItems   MenuItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([name])
}

model MenuItem {
  id          String      @id @default(uuid())
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  imageUrl    String?
  isAvailable Boolean     @default(true)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([categoryId])
  @@index([name])
  @@index([isAvailable])
}

enum OrderStatus {
  OPEN
  SENT_TO_KITCHEN
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

model Order {
  id         String      @id @default(uuid())
  tableId    String
  table      Table       @relation(fields: [tableId], references: [id], onDelete: Restrict)
  status     OrderStatus @default(OPEN)
  subtotal   Decimal     @db.Decimal(10, 2) @default(0)
  notes      String?
  orderItems OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([tableId])
  @@index([status])
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  lineTotal  Decimal  @db.Decimal(10, 2)
  notes      String?
  createdAt  DateTime @default(now())

  @@index([orderId])
  @@index([menuItemId])
}
